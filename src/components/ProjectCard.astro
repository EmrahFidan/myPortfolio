---
import type { Project } from '../data/projects'

interface Props {
  project: Project
  featured?: boolean
}

const { project, featured = false } = Astro.props

const categoryColors: Record<string, string> = {
  'ai-ml': 'text-violet-400 bg-violet-500/10 border-violet-500/20',
  'web': 'text-cyan-400 bg-cyan-500/10 border-cyan-500/20',
  'mobile': 'text-emerald-400 bg-emerald-500/10 border-emerald-500/20',
  'other': 'text-amber-400 bg-amber-500/10 border-amber-500/20',
}

const categoryLabels: Record<string, string> = {
  'ai-ml': 'AI / ML',
  'web': 'Web',
  'mobile': 'Mobile',
  'other': 'Other',
}
---

<div
  data-category={project.category}
  class={`bento-card bento-card-accent group flex flex-col gap-4 h-full ${featured ? 'md:col-span-2' : ''}`}
>
  <!-- Header -->
  <div class="flex items-start justify-between gap-2">
    <div class="flex-1">
      <div class="flex items-center gap-2 mb-1.5">
        <span class={`text-xs px-2 py-0.5 rounded-md border font-medium ${categoryColors[project.category]}`}>
          {categoryLabels[project.category]}
        </span>
        {featured && (
          <span class="text-xs px-2 py-0.5 rounded-md border text-amber-400 bg-amber-500/10 border-amber-500/20 font-medium">
            Featured
          </span>
        )}
      </div>
      <h3 class="font-semibold text-white group-hover:text-cyan-400 transition-colors text-base">
        {project.name}
      </h3>
    </div>
    <!-- Links -->
    <div class="flex items-center gap-2 shrink-0">
      {project.liveUrl && (
        <a
          href={project.liveUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="p-1.5 rounded-lg bg-gray-800 hover:bg-cyan-500/10 text-gray-400 hover:text-cyan-400 transition-colors"
          title="Live demo"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
          </svg>
        </a>
      )}
      <a
        href={project.url}
        target="_blank"
        rel="noopener noreferrer"
        class="p-1.5 rounded-lg bg-gray-800 hover:bg-gray-700 text-gray-400 hover:text-white transition-colors"
        title="GitHub"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
        </svg>
      </a>
    </div>
  </div>

  <!-- Description -->
  <p class="text-gray-400 text-sm leading-relaxed flex-1">
    {project.description}
  </p>

  <!-- Tags -->
  <div class="flex flex-wrap gap-1.5">
    {project.tags.slice(0, 4).map(tag => (
      <span class="px-2 py-0.5 text-xs rounded-md bg-gray-800 text-gray-500 border border-gray-700/50">
        {tag}
      </span>
    ))}
  </div>
</div>
