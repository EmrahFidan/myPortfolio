---
import { fetchPublicRepos } from '../lib/github'
import ProjectCard from './ProjectCard.astro'

const projects = await fetchPublicRepos()
const featured = projects.filter(p => p.featured)
const rest = projects.filter(p => !p.featured)
---

<section id="projects" class="py-24 px-6 relative">
  <div class="glow-line max-w-6xl mx-auto mb-20 reveal"></div>

  <div class="max-w-6xl mx-auto">
    <div class="mb-12 flex flex-col sm:flex-row sm:items-end sm:justify-between gap-6 reveal">
      <div>
        <p class="text-xs font-semibold tracking-[0.2em] uppercase mb-3" style="color: var(--accent);">Work</p>
        <h2 class="text-4xl md:text-5xl font-extrabold tracking-tight" style="font-family: 'Bricolage Grotesque', sans-serif;">Projects</h2>
      </div>
      <!-- Filter buttons -->
      <div class="flex gap-2 flex-wrap" id="filter-buttons">
        <button data-filter="all" class="filter-btn active">All</button>
        <button data-filter="ai-ml" class="filter-btn">AI / ML</button>
        <button data-filter="web" class="filter-btn">Web</button>
        <button data-filter="mobile" class="filter-btn">Mobile</button>
        <button data-filter="other" class="filter-btn">Other</button>
      </div>
    </div>

    <!-- Featured projects — larger span, puzzle-like layout -->
    {featured.length > 0 && (
      <div class="grid grid-cols-1 md:grid-cols-6 gap-5 mb-5" id="featured-grid">
        {featured.slice(0, 1).map((project, i) => (
          <div data-category={project.category} class={`md:col-span-4 reveal reveal-delay-${Math.min(i+1,5)}`}>
            <ProjectCard project={project} featured={true} delay={i + 1} />
          </div>
        ))}
        {featured.slice(1, 3).map((project, i) => (
          <div data-category={project.category} class={`md:col-span-2 reveal reveal-delay-${Math.min(i+2,5)}`}>
            <ProjectCard project={project} featured={true} delay={i + 2} />
          </div>
        ))}
        {featured.slice(3).map((project, i) => (
          <div data-category={project.category} class={`md:col-span-3 reveal reveal-delay-${Math.min(i+3,5)}`}>
            <ProjectCard project={project} featured={true} delay={i + 3} />
          </div>
        ))}
      </div>
    )}

    <!-- Rest — 3-col grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-5" id="projects-grid">
      {rest.map((project, i) => (
        <div data-category={project.category} class={`reveal reveal-delay-${Math.min(i % 3 + 1, 5)}`}>
          <ProjectCard project={project} featured={false} delay={i % 3 + 1} />
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .filter-btn {
    padding: 0.4rem 1rem;
    font-size: 0.8rem;
    font-weight: 500;
    border-radius: 9999px;
    border: 1px solid var(--border-subtle);
    background: transparent;
    color: var(--text-muted);
    cursor: pointer;
    transition: all 0.2s ease;
    font-family: 'Outfit', sans-serif;
  }
  .filter-btn:hover {
    border-color: var(--border-hover);
    color: var(--text-secondary);
  }
  .filter-btn.active {
    background: var(--accent-dim);
    border-color: rgba(0, 255, 194, 0.25);
    color: var(--accent);
  }
</style>

<script>
  const buttons = document.querySelectorAll('.filter-btn')
  const wrappers = document.querySelectorAll('[data-category]')

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = (btn as HTMLElement).dataset.filter

      buttons.forEach(b => b.classList.remove('active'))
      btn.classList.add('active')

      wrappers.forEach(wrapper => {
        const el = wrapper as HTMLElement
        if (filter === 'all' || el.dataset.category === filter) {
          el.style.display = ''
          el.style.opacity = '0'
          el.style.transform = 'translateY(12px)'
          requestAnimationFrame(() => {
            el.style.transition = 'opacity 0.3s ease, transform 0.3s ease'
            el.style.opacity = '1'
            el.style.transform = 'translateY(0)'
          })
        } else {
          el.style.display = 'none'
        }
      })
    })
  })
</script>
