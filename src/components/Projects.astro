---
import { fetchPublicRepos } from '../lib/github'
import ProjectCard from './ProjectCard.astro'

const projects = await fetchPublicRepos()
const spotlight = projects.filter(p => p.liveUrl || p.contributor).slice(0, 4)
const spotlightNames = new Set(spotlight.map(p => p.name))
const rest = projects.filter(p => !spotlightNames.has(p.name))
const allCount = projects.length
---

<section id="projects" class="py-24 px-6 relative">
  <div class="glow-line max-w-6xl mx-auto mb-20 reveal"></div>

  <div class="max-w-6xl mx-auto">

    <!-- Header -->
    <div class="mb-8 reveal">
      <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 mb-6">
        <div>
          <p class="text-xs font-semibold tracking-[0.2em] uppercase mb-3" style="color: var(--accent);">Work</p>
          <h2 class="text-4xl md:text-5xl font-extrabold tracking-tight" style="font-family: 'Bricolage Grotesque', sans-serif;">Projects</h2>
        </div>
      </div>
      <div class="filter-bar" id="filter-buttons">
        <button data-filter="all" class="filter-btn active">All <span class="filter-count">{allCount}</span></button>
        <button data-filter="ai-ml" class="filter-btn">AI / ML</button>
        <button data-filter="web" class="filter-btn">Web</button>
        <button data-filter="mobile" class="filter-btn">Mobile</button>
        <button data-filter="other" class="filter-btn">Other</button>
      </div>
    </div>

    <!-- Spotlight: Live & Highlighted — 2 col, auto height -->
    {spotlight.length > 0 && (
      <div class="mb-10">
        <p class="section-label accent-label reveal">⚡ Live & Highlighted</p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {spotlight.map((p, i) => (
            <div data-category={p.category} class={`reveal reveal-delay-${Math.min(i+1,4)}`}>
              <ProjectCard project={p} featured={p.featured} size="wide" delay={i+1} />
            </div>
          ))}
        </div>
      </div>
    )}

    <!-- All other projects — 3 col, auto height -->
    {rest.length > 0 && (
      <div>
        <p class="section-label muted-label reveal">All Projects</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4" id="rest-grid">
          {rest.map((p, i) => (
            <div data-category={p.category} class={`reveal reveal-delay-${Math.min((i%3)+1, 4)}`}>
              <ProjectCard project={p} featured={p.featured} size="sm" delay={(i%3)+1} />
            </div>
          ))}
        </div>
      </div>
    )}

  </div>
</section>

<style>
  .filter-bar {
    display: flex; gap: 0.5rem; flex-wrap: wrap;
    padding: 0.65rem 1rem;
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: 1rem;
    position: sticky; top: 4.25rem; z-index: 30;
    backdrop-filter: blur(16px);
  }
  .filter-btn {
    display: inline-flex; align-items: center; gap: 0.4rem;
    padding: 0.32rem 0.85rem; font-size: 0.78rem; font-weight: 500;
    border-radius: 9999px; border: 1px solid var(--border-subtle);
    background: transparent; color: var(--text-muted);
    cursor: pointer; transition: all 0.2s ease; font-family: 'Outfit', sans-serif;
  }
  .filter-btn:hover { border-color: var(--border-hover); color: var(--text-secondary); }
  .filter-btn.active { background: var(--accent-dim); border-color: rgba(0,255,194,0.3); color: var(--accent); }
  .filter-count {
    font-size: 0.62rem; padding: 0.04rem 0.32rem; border-radius: 9999px;
    background: rgba(139,148,158,0.1); color: var(--text-muted);
  }
  .filter-btn.active .filter-count { background: rgba(0,255,194,0.12); color: var(--accent); }

  .section-label {
    font-size: 0.68rem; font-weight: 700; letter-spacing: 0.15em;
    text-transform: uppercase; margin-bottom: 0.75rem;
  }
  .accent-label { color: var(--accent); }
  .muted-label  { color: var(--text-muted); margin-top: 0.5rem; }
</style>

<script>
  const buttons = document.querySelectorAll('.filter-btn')
  const cards   = document.querySelectorAll('[data-category]')

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = (btn as HTMLElement).dataset.filter
      buttons.forEach(b => b.classList.remove('active'))
      btn.classList.add('active')

      cards.forEach(card => {
        const el = card as HTMLElement
        const visible = filter === 'all' || el.dataset.category === filter
        if (visible) {
          el.style.display = ''
          requestAnimationFrame(() => {
            el.style.transition = 'opacity 0.25s ease, transform 0.25s ease'
            el.style.opacity = '1'
            el.style.transform = 'translateY(0)'
          })
        } else {
          el.style.opacity = '0'
          el.style.transform = 'translateY(8px)'
          setTimeout(() => { el.style.display = 'none' }, 250)
        }
      })
    })
  })
</script>
