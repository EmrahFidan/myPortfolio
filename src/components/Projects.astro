---
import { fetchPublicRepos } from '../lib/github'
import ProjectCard from './ProjectCard.astro'

const projects = await fetchPublicRepos()

// Spotlight: live or contributor projects (top 4 max)
const spotlight = projects.filter(p => p.liveUrl || p.contributor).slice(0, 4)
const spotlightNames = new Set(spotlight.map(p => p.name))

// Rest: everything not in spotlight
const rest = projects.filter(p => !spotlightNames.has(p.name))

// Bento size map for spotlight — first is hero, others fill the row
const spotlightSizes: Array<'hero' | 'tall' | 'wide' | 'sm'> = ['hero', 'tall', 'wide', 'wide']

const allCount = projects.length
---

<section id="projects" class="py-24 px-6 relative">
  <div class="glow-line max-w-6xl mx-auto mb-20 reveal"></div>

  <div class="max-w-6xl mx-auto">

    <!-- Header -->
    <div class="mb-8 reveal">
      <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 mb-6">
        <div>
          <p class="text-xs font-semibold tracking-[0.2em] uppercase mb-3" style="color: var(--accent);">Work</p>
          <h2 class="text-4xl md:text-5xl font-extrabold tracking-tight" style="font-family: 'Bricolage Grotesque', sans-serif;">Projects</h2>
        </div>
      </div>

      <!-- Filter bar -->
      <div class="filter-bar" id="filter-buttons">
        <button data-filter="all" class="filter-btn active">All <span class="filter-count">{allCount}</span></button>
        <button data-filter="ai-ml" class="filter-btn">AI / ML</button>
        <button data-filter="web" class="filter-btn">Web</button>
        <button data-filter="mobile" class="filter-btn">Mobile</button>
        <button data-filter="other" class="filter-btn">Other</button>
      </div>
    </div>

    <!-- ── Spotlight section ── -->
    {spotlight.length > 0 && (
      <div class="mb-3">
        <p class="spotlight-label reveal">⚡ Live & Highlighted</p>
        <div class="spotlight-grid" id="spotlight-grid">
          {spotlight.map((project, i) => (
            <div
              data-category={project.category}
              data-section="spotlight"
              class={`bento-cell spotlight-${spotlightSizes[i]} reveal reveal-delay-${i + 1}`}
            >
              <ProjectCard
                project={project}
                featured={project.featured}
                size={spotlightSizes[i]}
                delay={i + 1}
              />
            </div>
          ))}
        </div>
      </div>
    )}

    <!-- ── Rest in compact bento ── -->
    {rest.length > 0 && (
      <div>
        <p class="rest-label reveal">All Projects</p>
        <div class="rest-grid" id="rest-grid">
          {rest.map((project, i) => (
            <div
              data-category={project.category}
              data-section="rest"
              class={`bento-cell reveal reveal-delay-${Math.min((i % 4) + 1, 5)}`}
            >
              <ProjectCard
                project={project}
                featured={project.featured}
                size="sm"
                delay={(i % 4) + 1}
              />
            </div>
          ))}
        </div>
      </div>
    )}

  </div>
</section>

<style>
  /* ── Filter bar ── */
  .filter-bar {
    display: flex; gap: 0.5rem; flex-wrap: wrap;
    padding: 0.65rem 1rem;
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: 1rem;
    position: sticky; top: 4.25rem; z-index: 30;
    backdrop-filter: blur(16px);
  }
  .filter-btn {
    display: inline-flex; align-items: center; gap: 0.4rem;
    padding: 0.32rem 0.85rem; font-size: 0.78rem; font-weight: 500;
    border-radius: 9999px; border: 1px solid var(--border-subtle);
    background: transparent; color: var(--text-muted);
    cursor: pointer; transition: all 0.2s ease; font-family: 'Outfit', sans-serif;
  }
  .filter-btn:hover { border-color: var(--border-hover); color: var(--text-secondary); }
  .filter-btn.active { background: var(--accent-dim); border-color: rgba(0,255,194,0.3); color: var(--accent); }
  .filter-count {
    font-size: 0.62rem; padding: 0.04rem 0.32rem; border-radius: 9999px;
    background: rgba(139,148,158,0.1); color: var(--text-muted);
  }
  .filter-btn.active .filter-count { background: rgba(0,255,194,0.12); color: var(--accent); }

  /* ── Section labels ── */
  .spotlight-label {
    font-size: 0.7rem; font-weight: 700; letter-spacing: 0.15em;
    text-transform: uppercase; color: var(--accent);
    margin-bottom: 0.6rem;
  }
  .rest-label {
    font-size: 0.7rem; font-weight: 600; letter-spacing: 0.12em;
    text-transform: uppercase; color: var(--text-muted);
    margin-bottom: 0.6rem; margin-top: 2rem;
  }

  /* ── Spotlight bento — 4 cols, taller rows ── */
  .spotlight-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-auto-rows: 240px;
    gap: 6px;
    grid-auto-flow: dense;
  }

  .spotlight-hero { grid-column: span 2; grid-row: span 2; }
  .spotlight-tall { grid-column: span 1; grid-row: span 2; }
  .spotlight-wide { grid-column: span 2; grid-row: span 1; }
  .spotlight-sm   { grid-column: span 1; grid-row: span 1; }

  /* ── Rest bento — 4 cols, standard rows ── */
  .rest-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-auto-rows: 220px;
    gap: 6px;
    grid-auto-flow: dense;
  }

  /* All cells fill height */
  .bento-cell { min-height: 0; }
  .bento-cell > div { height: 100%; }

  /* Tablet */
  @media (max-width: 860px) {
    .spotlight-grid, .rest-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .spotlight-hero { grid-column: span 2; grid-row: span 2; }
    .spotlight-tall { grid-column: span 1; grid-row: span 2; }
    .spotlight-wide { grid-column: span 2; grid-row: span 1; }
    .spotlight-sm   { grid-column: span 1; grid-row: span 1; }
  }

  /* Mobile */
  @media (max-width: 480px) {
    .spotlight-grid, .rest-grid {
      grid-template-columns: 1fr; grid-auto-rows: auto;
    }
    .spotlight-hero, .spotlight-tall, .spotlight-wide, .spotlight-sm {
      grid-column: span 1; grid-row: span 1;
    }
  }
</style>

<script>
  const buttons = document.querySelectorAll('.filter-btn')
  const cells   = document.querySelectorAll('.bento-cell[data-category]')

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = (btn as HTMLElement).dataset.filter
      buttons.forEach(b => b.classList.remove('active'))
      btn.classList.add('active')

      cells.forEach(cell => {
        const el = cell as HTMLElement
        const visible = filter === 'all' || el.dataset.category === filter
        if (visible) {
          el.style.display = ''
          requestAnimationFrame(() => {
            el.style.transition = 'opacity 0.25s ease, transform 0.25s ease'
            el.style.opacity = '1'
            el.style.transform = 'scale(1)'
          })
        } else {
          el.style.opacity = '0'
          el.style.transform = 'scale(0.96)'
          setTimeout(() => { el.style.display = 'none' }, 250)
        }
      })
    })
  })
</script>
