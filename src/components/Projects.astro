---
import { fetchPublicRepos } from '../lib/github'
import ProjectCard from './ProjectCard.astro'

const projects = await fetchPublicRepos()
const featured = projects.filter(p => p.featured)
const rest = projects.filter(p => !p.featured)
---

<section id="projects" class="py-24 px-6 relative">
  <div class="glow-line max-w-6xl mx-auto mb-20 reveal"></div>

  <div class="max-w-6xl mx-auto">
    <div class="mb-12 flex flex-col sm:flex-row sm:items-end sm:justify-between gap-6 reveal">
      <div>
        <p class="text-xs font-semibold tracking-[0.2em] uppercase mb-3" style="color: var(--accent);">Work</p>
        <h2 class="text-4xl md:text-5xl font-extrabold tracking-tight" style="font-family: 'Bricolage Grotesque', sans-serif;">Projects</h2>
      </div>
      <!-- Filter buttons -->
      <div class="flex gap-2 flex-wrap" id="filter-buttons">
        <button data-filter="all" class="filter-btn active">
          All
        </button>
        <button data-filter="ai-ml" class="filter-btn">
          AI / ML
        </button>
        <button data-filter="web" class="filter-btn">
          Web
        </button>
        <button data-filter="mobile" class="filter-btn">
          Mobile
        </button>
        <button data-filter="other" class="filter-btn">
          Other
        </button>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-4 gap-5" id="projects-grid">
      {featured.map((project, i) => (
        <ProjectCard project={project} featured={true} delay={Math.min(i + 1, 5)} />
      ))}
      {rest.map((project, i) => (
        <ProjectCard project={project} featured={false} delay={Math.min(i + 1, 5)} />
      ))}
    </div>
  </div>
</section>

<style>
  .filter-btn {
    padding: 0.4rem 1rem;
    font-size: 0.8rem;
    font-weight: 500;
    border-radius: 9999px;
    border: 1px solid var(--border-subtle);
    background: transparent;
    color: var(--text-muted);
    cursor: pointer;
    transition: all 0.2s ease;
    font-family: 'Outfit', sans-serif;
  }
  .filter-btn:hover {
    border-color: var(--border-hover);
    color: var(--text-secondary);
  }
  .filter-btn.active {
    background: var(--accent-dim);
    border-color: rgba(0, 255, 194, 0.25);
    color: var(--accent);
  }
</style>

<script>
  const buttons = document.querySelectorAll('.filter-btn')
  const cards = document.querySelectorAll('[data-category]')

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = (btn as HTMLElement).dataset.filter

      buttons.forEach(b => b.classList.remove('active'))
      btn.classList.add('active')

      cards.forEach(card => {
        const el = card as HTMLElement
        if (filter === 'all' || el.dataset.category === filter) {
          el.style.display = 'flex'
          el.style.opacity = '0'
          el.style.transform = 'translateY(12px)'
          requestAnimationFrame(() => {
            el.style.transition = 'opacity 0.3s ease, transform 0.3s ease'
            el.style.opacity = '1'
            el.style.transform = 'translateY(0)'
          })
        } else {
          el.style.display = 'none'
        }
      })
    })
  })
</script>
