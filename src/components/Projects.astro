---
import { projects } from '../data/projects'
import ProjectCard from './ProjectCard.astro'

const featured = projects.filter(p => p.featured)
const rest = projects.filter(p => !p.featured)
---

<section id="projects" class="py-16 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="mb-8 flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4">
      <div>
        <p class="text-sm text-cyan-500 font-medium tracking-wide uppercase mb-2">Work</p>
        <h2 class="text-3xl font-bold text-white">Projects</h2>
      </div>
      <!-- Filter buttons -->
      <div class="flex gap-2 flex-wrap" id="filter-buttons">
        <button data-filter="all" class="filter-btn active px-3 py-1.5 text-sm rounded-lg border transition-colors">
          All ({projects.length})
        </button>
        <button data-filter="ai-ml" class="filter-btn px-3 py-1.5 text-sm rounded-lg border transition-colors">
          AI / ML
        </button>
        <button data-filter="web" class="filter-btn px-3 py-1.5 text-sm rounded-lg border transition-colors">
          Web
        </button>
        <button data-filter="mobile" class="filter-btn px-3 py-1.5 text-sm rounded-lg border transition-colors">
          Mobile
        </button>
        <button data-filter="other" class="filter-btn px-3 py-1.5 text-sm rounded-lg border transition-colors">
          Other
        </button>
      </div>
    </div>

    <!-- Featured projects grid -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-4" id="projects-grid">
      {featured.map(project => (
        <ProjectCard project={project} featured={true} />
      ))}
      {rest.map(project => (
        <ProjectCard project={project} featured={false} />
      ))}
    </div>
  </div>
</section>

<style>
  .filter-btn {
    background-color: rgb(17 17 17);
    border-color: rgb(31 41 55);
    color: rgb(156 163 175);
  }
  .filter-btn:hover {
    border-color: rgb(55 65 81);
    color: rgb(229 231 235);
  }
  .filter-btn.active {
    background-color: rgb(6 182 212 / 0.1);
    border-color: rgb(6 182 212 / 0.3);
    color: rgb(6 182 212);
  }
</style>

<script>
  const buttons = document.querySelectorAll('.filter-btn')
  const cards = document.querySelectorAll('[data-category]')

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = (btn as HTMLElement).dataset.filter

      buttons.forEach(b => b.classList.remove('active'))
      btn.classList.add('active')

      cards.forEach(card => {
        const el = card as HTMLElement
        if (filter === 'all' || el.dataset.category === filter) {
          el.style.display = 'flex'
        } else {
          el.style.display = 'none'
        }
      })
    })
  })
</script>
