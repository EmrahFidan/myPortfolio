---
---

<section class="relative pt-32 pb-24 px-6 overflow-hidden">
  <!-- Floating orbs -->
  <div class="orb orb-mint w-[500px] h-[500px] -top-40 -right-40" style="position: absolute;"></div>
  <div class="orb orb-purple w-[400px] h-[400px] top-20 -left-32" style="position: absolute;"></div>
  <div class="orb orb-blue w-[300px] h-[300px] bottom-0 right-1/4" style="position: absolute;"></div>

  <div class="max-w-6xl mx-auto relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-5">

      <!-- Main intro — large card -->
      <div class="card lg:col-span-8 reveal" style="padding: 3rem;">
        <div class="flex items-center gap-2 mb-6">
          <span class="w-2 h-2 rounded-full animate-pulse" style="background: var(--accent);"></span>
          <span class="text-xs font-semibold tracking-[0.2em] uppercase" style="color: var(--accent);">Available for work</span>
        </div>
        <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight leading-[0.95] mb-6" style="font-family: 'Bricolage Grotesque', sans-serif;">
          <span class="gradient-text">Emrah</span><br/>
          <span style="color: var(--text-primary);">Fidan</span>
        </h1>
        <p class="text-lg md:text-xl max-w-lg leading-relaxed" style="color: var(--text-secondary);">
          Building AI-powered web & mobile applications. From computer vision to synthetic data — turning complex problems into elegant solutions.
        </p>
      </div>

      <!-- Avatar card -->
      <div class="card card-glow lg:col-span-4 flex items-center justify-center reveal reveal-delay-1" style="min-height: 240px;">
        <div class="relative">
          <div class="w-28 h-28 rounded-3xl flex items-center justify-center text-5xl" style="background: linear-gradient(135deg, var(--accent-dim), var(--purple-dim)); border: 1px solid rgba(0, 255, 194, 0.15);">
            👨‍💻
          </div>
          <div class="absolute -bottom-1 -right-1 w-5 h-5 rounded-full border-2" style="background: var(--accent); border-color: var(--bg-card);"></div>
        </div>
      </div>

      <!-- Tech tags card -->
      <div class="card lg:col-span-5 reveal reveal-delay-2">
        <p class="text-xs font-semibold tracking-[0.15em] uppercase mb-4" style="color: var(--text-muted);">Core Stack</p>
        <div class="flex flex-wrap gap-2">
          <span class="tag tag-mint">React</span>
          <span class="tag tag-mint">TypeScript</span>
          <span class="tag tag-purple">Python</span>
          <span class="tag tag-blue">React Native</span>
          <span class="tag tag-amber">FastAPI</span>
          <span class="tag tag-rose">Firebase</span>
        </div>
      </div>

      <!-- GitHub card -->
      <a
        href="https://github.com/EmrahFidan"
        target="_blank"
        rel="noopener noreferrer"
        class="card card-glow group lg:col-span-3 flex flex-col justify-between reveal reveal-delay-3 cursor-pointer"
      >
        <svg class="w-7 h-7 transition-colors duration-200" style="color: var(--text-muted);" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
        </svg>
        <div class="mt-6">
          <p class="font-semibold text-sm" style="color: var(--text-primary);">GitHub</p>
          <p class="text-xs mt-0.5" style="color: var(--text-muted);">@EmrahFidan</p>
        </div>
        <div class="absolute top-4 right-4 opacity-0 group-hover:opacity-100 transition-opacity">
          <svg class="w-4 h-4" style="color: var(--accent);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17L17 7M17 7H7M17 7v10"/>
          </svg>
        </div>
      </a>

      <!-- LinkedIn card -->
      <a
        href="https://linkedin.com/in/emrahfidan"
        target="_blank"
        rel="noopener noreferrer"
        class="card card-purple group lg:col-span-2 flex flex-col justify-between reveal reveal-delay-4 cursor-pointer"
      >
        <svg class="w-7 h-7 transition-colors duration-200" style="color: var(--text-muted);" fill="currentColor" viewBox="0 0 24 24">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
        <div class="mt-6">
          <p class="font-semibold text-sm" style="color: var(--text-primary);">LinkedIn</p>
          <p class="text-xs mt-0.5" style="color: var(--text-muted);">Connect</p>
        </div>
        <div class="absolute top-4 right-4 opacity-0 group-hover:opacity-100 transition-opacity">
          <svg class="w-4 h-4" style="color: var(--purple);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17L17 7M17 7H7M17 7v10"/>
          </svg>
        </div>
      </a>

      <!-- Location + Stats card -->
      <div class="card lg:col-span-2 reveal reveal-delay-5">
        <div class="flex flex-col gap-6">
          <div>
            <p class="text-xs font-semibold tracking-[0.15em] uppercase mb-2" style="color: var(--text-muted);">Location</p>
            <p class="text-sm font-medium" style="color: var(--text-primary);">📍 Turkey</p>
          </div>
          <div>
            <p class="text-3xl font-bold" style="font-family: 'Bricolage Grotesque', sans-serif; color: var(--accent);">15+</p>
            <p class="text-xs mt-1" style="color: var(--text-muted);">Public Repos</p>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
