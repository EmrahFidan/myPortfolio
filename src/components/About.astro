---
---

<section id="about" class="py-24 px-6 relative">
  <div class="glow-line max-w-6xl mx-auto mb-20 reveal"></div>

  <div class="max-w-6xl mx-auto">
    <div class="mb-12 reveal">
      <p class="text-xs font-semibold tracking-[0.2em] uppercase mb-3" style="color: var(--accent);">Background</p>
      <h2 class="text-4xl md:text-5xl font-extrabold tracking-tight" style="font-family: 'Bricolage Grotesque', sans-serif;">About</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-6 gap-5">

      <!-- Bio — wide -->
      <div class="card md:col-span-4 reveal reveal-delay-1" style="padding: 2.5rem;">
        <div class="flex items-center gap-3 mb-5">
          <div class="w-8 h-8 rounded-xl flex items-center justify-center text-sm" style="background: var(--accent-dim); border: 1px solid rgba(0, 255, 194, 0.15);">👋</div>
          <h3 class="font-bold text-base" style="font-family: 'Bricolage Grotesque', sans-serif;">Hi there</h3>
        </div>
        <p class="leading-relaxed mb-4" style="color: var(--text-secondary);">
          I'm a software developer focused on building full-stack web and mobile applications with a strong emphasis on AI integration. I enjoy working across the stack — from React/React Native frontends to Python/FastAPI backends and machine learning pipelines.
        </p>
        <p class="leading-relaxed" style="color: var(--text-secondary);">
          My projects range from computer vision systems (YOLOv11 for plant disease detection) to synthetic data generation with CTGAN, SaaS platforms, and cross-platform mobile apps.
        </p>
      </div>

      <!-- Status + Education stacked -->
      <div class="md:col-span-2 flex flex-col gap-5">
        <!-- Status -->
        <div class="card card-glow reveal reveal-delay-2">
          <div class="flex items-center gap-3 mb-3">
            <span class="relative flex h-3 w-3">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full opacity-75" style="background: var(--accent);"></span>
              <span class="relative inline-flex rounded-full h-3 w-3" style="background: var(--accent);"></span>
            </span>
            <span class="text-sm font-semibold" style="color: var(--accent);">Available</span>
          </div>
          <p class="text-xs leading-relaxed" style="color: var(--text-muted);">
            Open to new opportunities and interesting projects.
          </p>
        </div>

        <!-- Education -->
        <div class="card reveal reveal-delay-3">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-8 h-8 rounded-xl flex items-center justify-center text-sm" style="background: var(--purple-dim); border: 1px solid rgba(123, 97, 255, 0.15);">🎓</div>
            <h3 class="font-bold text-sm" style="font-family: 'Bricolage Grotesque', sans-serif;">Education</h3>
          </div>
          <p class="text-sm font-medium" style="color: var(--text-primary);">Computer Engineering</p>
          <p class="text-xs mt-1" style="color: var(--text-muted);">Adnan Menderes University</p>
        </div>
      </div>

      <!-- Interests — wide -->
      <div class="card md:col-span-6 reveal reveal-delay-4">
        <div class="flex items-center gap-3 mb-5">
          <div class="w-8 h-8 rounded-xl flex items-center justify-center text-sm" style="background: rgba(240, 180, 41, 0.08); border: 1px solid rgba(240, 180, 41, 0.15);">💡</div>
          <h3 class="font-bold text-base" style="font-family: 'Bricolage Grotesque', sans-serif;">Interests</h3>
        </div>
        <div class="flex flex-wrap gap-2">
          {['Artificial Intelligence', 'Computer Vision', 'Mobile Development', 'Open Source', 'SaaS Platforms', 'Deep Learning', 'Full-Stack Architecture'].map(i => (
            <span class="tag tag-neutral">{i}</span>
          ))}
        </div>
      </div>

    </div>
  </div>
</section>
